# ----------------------------------------------------------------------
# Badminton Tournament Manager - Hostinger / Apache Deployment
# ----------------------------------------------------------------------

RewriteEngine On
RewriteBase /

# 1. CRITICAL: Prevent ANY API routes from ever being rewritten to index.html
# This prevents the dreaded "Unexpected token < in JSON" error caused by Express or Apache 
# serving index.html for broken or unhandled API requests.
RewriteCond %{REQUEST_URI} ^/api [NC]
RewriteRule ^ - [L]

# 2. If mod_passenger (Hostinger cPanel Node.js Application Manager) is active:
<IfModule mod_passenger.c>
    PassengerEnabled on
    PassengerAppType node
    PassengerStartupFile server.js
    PassengerAppEnv production
</IfModule>

# 3. Standalone Port Routing (If running on a VPS or port via PM2/node process)
# If mod_passenger is NOT active, proxy /api requests to your Node port (default 3000)
<IfModule !mod_passenger.c>
    # Proxy all /api calls to the backend port
    RewriteRule ^api/(.*)$ http://127.0.0.1:3000/api/$1 [P,L]
</IfModule>

# 4. Standard SPA Routing Fallback
# Serve actual static assets directly (CSS, JS, images, etc.) if they exist
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback all other client-side/frontend routes (e.g., /dashboard, /public) to index.html
RewriteRule ^(.*)$ index.html [L]

# Ensure Authorization headers are passed to your Express backend
RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]
